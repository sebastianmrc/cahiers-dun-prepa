---
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  titre?: string;
  description?: string;
}
const { titre, description = "Polycopiés de CPGE PT en accès libre." } = Astro.props;
const titreComplet = titre ? `${titre} — Cahiers d'un prépa` : "Cahiers d'un prépa";
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titreComplet}</title>
    <meta name="description" content={description} />
    <Font cssVariable="--font-serif" preload />
    <Font cssVariable="--font-sans" preload />
  </head>
  <body>
    <Header />
    <main class="contenu">
      <slot />
    </main>
    <Footer />
  </body>
</html>