---
import { getCollection } from 'astro:content';
import { FONCTIONS } from '../data/fonctions';

const tousPolys = await getCollection('polys');

// Pour chaque fonction : ses infos + ses polys associés (calculé au build)
const donnees = FONCTIONS.map((f) => ({
  id: f.id,
  label: f.label,
  definition: f.definition,
  composants: [...f.composants],
  polys: tousPolys
    .filter((p) => p.data.fonctions.includes(f.id))
    .sort((a, b) => a.data.ordre - b.data.ordre)
    .map((p) => ({ titre: p.data.titre, pdf: p.data.pdf })),
}));

const info = FONCTIONS.filter((f) => f.chaine === 'information');
const puissance = FONCTIONS.filter((f) => f.chaine === 'puissance');
---
<div class="chaines">
  <section class="chaine">
    <h3>Chaîne d'information</h3>
    <ol class="blocs">
      {info.map((f) => (
        <li><a href={`/si/fonction/${f.id}/`} class="bloc" data-fonction={f.id}>{f.label}</a></li>
      ))}
    </ol>
  </section>

  <section class="chaine">
    <h3>Chaîne de puissance</h3>
    <ol class="blocs">
      {puissance.map((f) => (
        <li><a href={`/si/fonction/${f.id}/`} class="bloc" data-fonction={f.id}>{f.label}</a></li>
      ))}
    </ol>
  </section>

  <div id="panneau" class="panneau" hidden></div>
</div>

<script define:vars={{ donnees }}>
  const parId = Object.fromEntries(donnees.map((d) => [d.id, d]));
  const panneau = document.getElementById('panneau');
  const blocs = document.querySelectorAll('.bloc');

  function afficher(id) {
    const d = parId[id];
    if (!d) return;
    const polysHtml = d.polys.length
      ? d.polys.map((p) => `<li><a href="${p.pdf}" target="_blank" rel="noopener">${p.titre}</a></li>`).join('')
      : '<li>Aucun polycopié pour l’instant.</li>';
    panneau.innerHTML = `
      <button type="button" class="fermer" aria-label="Fermer le panneau">×</button>
      <h2 tabindex="-1">${d.label}</h2>
      <p>${d.definition}</p>
      <p>Composants types : ${d.composants.join(', ')}.</p>
      <ul class="polys-panneau">${polysHtml}</ul>
      <p><a href="/si/fonction/${id}/">Voir la page complète →</a></p>
    `;
    panneau.hidden = false;
    blocs.forEach((b) => b.removeAttribute('aria-current'));
    document.querySelector(`.bloc[data-fonction="${id}"]`)?.setAttribute('aria-current', 'true');
    panneau.querySelector('.fermer').addEventListener('click', fermerEtHistorique);
    panneau.querySelector('h2').focus();
  }

  function cacher() {
    panneau.hidden = true;
    panneau.innerHTML = '';
    blocs.forEach((b) => b.removeAttribute('aria-current'));
  }
  function fermerEtHistorique() { cacher(); history.pushState({}, '', '/si/'); }

  blocs.forEach((bloc) => {
    bloc.addEventListener('click', (e) => {
      e.preventDefault();
      const id = bloc.dataset.fonction;
      afficher(id);
      history.pushState({ fonction: id }, '', `/si/fonction/${id}/`);
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !panneau.hidden) fermerEtHistorique();
  });

  window.addEventListener('popstate', () => {
    const m = location.pathname.match(/^\/si\/fonction\/([^/]+)\/?$/);
    if (m && parId[m[1]]) afficher(m[1]); else cacher();
  });
</script>

<style>
  .chaines { display: flex; flex-direction: column; gap: 2rem; margin: 2rem 0; }
  .chaine h3 { margin: 0 0 0.75rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: #555; }
  .blocs { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .blocs li { display: flex; align-items: center; }
  .blocs li:not(:last-child)::after { content: "→"; margin-left: 0.6rem; color: #999; }
  .bloc {
    display: inline-block; padding: 0.6rem 1rem;
    border: 1px solid var(--filet, #d8d5ce); border-radius: 6px;
    background: var(--papier, #faf9f6); color: inherit; text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .bloc:hover, .bloc:focus-visible,
  .bloc[aria-current="true"] { border-color: var(--accent, #b00); color: var(--accent, #b00); }
  .bloc[aria-current="true"] { font-weight: 600; }

  .panneau { position: relative; border: 1px solid var(--filet, #d8d5ce); border-radius: 8px; padding: 1.25rem 1.5rem; margin-top: 0.5rem; }
  .panneau h2 { margin: 0 0 0.5rem; outline: none; }
  .panneau .fermer { position: absolute; top: 0.5rem; right: 0.75rem; border: none; background: none; font-size: 1.4rem; line-height: 1; cursor: pointer; color: #888; }
  .panneau .polys-panneau { margin: 0.5rem 0; padding-left: 1.2rem; }
@media (max-width: 600px) {
    .blocs { flex-direction: column; align-items: stretch; }
    .blocs li { display: block; }
    .bloc { display: block; text-align: center; }
    .blocs li:not(:last-child)::after {
      content: "↓"; display: block; margin: 0.35rem 0 0; text-align: center;
    }
  }
</style>